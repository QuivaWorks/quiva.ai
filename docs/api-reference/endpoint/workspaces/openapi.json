      "patch": {
        "summary": "Update a space",
        "operationId": "updateSpace",
        "x-resource-type": "service",
        "x-resource": "microstrate.workspaces.patch.space",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
